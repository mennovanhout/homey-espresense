  "flow": {
    "triggers": [
      {
        "id": "when-device-is-closer-than-x-meters",
        "title": {
          "en": "When beacon is closer than x meters",
          "nl": "Als beacon dichter bij is dan x meter"
        },
        "titleFormatted": {
          "en": "When beacon [[deviceId]] is closer than [[distance]] meters",
          "nl": "Als beacon [[deviceId]] dichter bij is dan [[distance]] meter"
        },
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=espresense"
          },
          {
            "type": "autocomplete",
            "name": "deviceId",
            "placeholder": {
              "en": "Beacon"
            }
          },
          {
            "type": "number",
            "name": "distance",
            "placeholder": {
              "en": "Distance",
              "nl": "Afstand"
            },
            "min": 0,
            "max": 16,
            "step": 0.01
          }
        ],
        "tokens": [
          {
            "type": "number",
            "name": "device-distance",
            "title": {
              "en": "Beacon distance",
